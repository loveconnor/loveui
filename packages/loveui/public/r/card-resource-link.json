{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "card-resource-link",
  "description": "Resource link card",
  "registryDependencies": [
    "@loveui/card"
  ],
  "files": [
    {
      "path": "registry/default/examples/card-resource-link.tsx",
      "content": "import { BookOpenIcon, LinkIcon } from \"lucide-react\"\n\nimport { Card, CardContent } from \"@/registry/default/ui/card\"\n\nconst item = {\n  label: \"Documentation\",\n  description:\n    \"Find guides, API references, and examples to integrate with our platform.\",\n  link: \"View docs\",\n  icon: <BookOpenIcon aria-hidden=\"true\" />,\n}\n\nexport default function CardResourceLink() {\n  return (\n    <Card className=\"w-full max-w-xs p-0\">\n      <CardContent className=\"p-0\">\n        <div className=\"border-b px-4 py-3\">\n          <div className=\"flex items-center gap-2 text-muted-foreground [&_svg]:size-4\">\n            {item.icon}\n            <span className=\"text-sm font-medium text-foreground\">\n              {item.label}\n            </span>\n          </div>\n        </div>\n        <div className=\"space-y-3 p-4\">\n          <p className=\"text-sm leading-relaxed text-muted-foreground\">\n            {item.description}\n          </p>\n          <a\n            href=\"#\"\n            className=\"inline-flex items-center gap-1 text-xs font-medium text-primary hover:underline\"\n          >\n            <LinkIcon aria-hidden=\"true\" className=\"size-2.5 shrink-0\" />\n            {item.link}\n          </a>\n        </div>\n      </CardContent>\n    </Card>\n  )\n}\n",
      "type": "registry:example"
    }
  ],
  "categories": [
    "card"
  ],
  "type": "registry:example"
}
