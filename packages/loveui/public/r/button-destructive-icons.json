  "files": [
    {
      "path": "registry/default/examples/button-destructive-icons.tsx",
      "content": "import { ArrowRightIcon, TrashIcon } from \"lucide-react\"\n\nimport { Button } from \"@/registry/default/ui/button\"\n\nexport default function ButtonDestructiveIcons() {\n  return (\n    <div className=\"flex flex-wrap items-center gap-3\">\n      <Button variant=\"destructive\">\n        <TrashIcon />\n        Delete\n      </Button>\n      <Button variant=\"destructive\">\n        Delete\n        <ArrowRightIcon />\n      </Button>\n    </div>\n  )\n}\n",
      "type": "registry:example"
    }
  ],
  "categories": [
    "button"
  ],
  "type": "registry:example"
