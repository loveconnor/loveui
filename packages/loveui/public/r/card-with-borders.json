{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "card-with-borders",
  "description": "Card with bordered sections",
  "registryDependencies": [
    "@loveui/button",
    "@loveui/card"
  ],
  "files": [
    {
      "path": "registry/default/examples/card-with-borders.tsx",
      "content": "import { Button } from \"@/registry/default/ui/button\"\nimport {\n  Card,\n  CardContent,\n  CardFooter,\n  CardHeader,\n  CardTitle,\n} from \"@/registry/default/ui/card\"\n\nexport default function CardWithBorders() {\n  return (\n    <Card className=\"w-full max-w-xs\">\n      <CardHeader className=\"border-b\">\n        <CardTitle>Header with Border</CardTitle>\n      </CardHeader>\n      <CardContent>\n        <p>\n          The header and footer use borders to create visual separation between\n          card sections.\n        </p>\n      </CardContent>\n      <CardFooter className=\"border-t\">\n        <Button variant=\"outline\" className=\"w-full\">\n          Action\n        </Button>\n      </CardFooter>\n    </Card>\n  )\n}\n",
      "type": "registry:example"
    }
  ],
  "categories": [
    "card"
  ],
  "type": "registry:example"
}
