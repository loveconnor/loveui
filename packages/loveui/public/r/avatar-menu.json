{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "avatar-menu",
  "description": "Avatar account menu",
  "registryDependencies": [
    "@loveui/avatar",
    "@loveui/button",
    "@loveui/menu"
  ],
  "files": [
    {
      "path": "registry/default/examples/avatar-menu.tsx",
      "content": "import {\n  ChevronsUpDownIcon,\n  LogOutIcon,\n  PlusIcon,\n  SettingsIcon,\n  UserIcon,\n} from \"lucide-react\"\n\nimport {\n  Avatar,\n  AvatarFallback,\n  AvatarImage,\n} from \"@/registry/default/ui/avatar\"\nimport { Button } from \"@/registry/default/ui/button\"\nimport {\n  DropdownMenu,\n  DropdownMenuContent,\n  DropdownMenuGroup,\n  DropdownMenuItem,\n  DropdownMenuLabel,\n  DropdownMenuSeparator,\n  DropdownMenuTrigger,\n} from \"@/registry/default/ui/menu\"\n\nexport default function AvatarMenu() {\n  return (\n    <DropdownMenu>\n      <DropdownMenuTrigger\n        render={\n          <Button\n            variant=\"outline\"\n            size=\"sm\"\n            className=\"h-8 gap-1.5 rounded-full pr-2.5 pl-1\"\n          />\n        }\n      >\n        <Avatar className=\"size-6 border border-background\">\n          <AvatarImage\n            src=\"https://images.unsplash.com/photo-1542595913-85d69b0edbaf?w=96&h=96&dpr=2&q=80\"\n            alt=\"Liam Thompson\"\n          />\n          <AvatarFallback>LT</AvatarFallback>\n        </Avatar>\n        <span className=\"text-xs font-medium\">Liam Thompson</span>\n        <ChevronsUpDownIcon\n          className=\"size-3.5 opacity-60\"\n          aria-hidden=\"true\"\n        />\n      </DropdownMenuTrigger>\n      <DropdownMenuContent className=\"w-44\" align=\"center\" sideOffset={8}>\n        <DropdownMenuGroup>\n          <DropdownMenuLabel>Management</DropdownMenuLabel>\n          <DropdownMenuItem>\n            <UserIcon aria-hidden=\"true\" />\n            <span>Profile</span>\n          </DropdownMenuItem>\n          <DropdownMenuItem>\n            <SettingsIcon aria-hidden=\"true\" />\n            <span>Settings</span>\n          </DropdownMenuItem>\n        </DropdownMenuGroup>\n        <DropdownMenuSeparator />\n        <DropdownMenuGroup>\n          <DropdownMenuItem>\n            <UserIcon aria-hidden=\"true\" />\n            <span>Teams</span>\n          </DropdownMenuItem>\n          <DropdownMenuItem>\n            <PlusIcon aria-hidden=\"true\" />\n            <span>Invite</span>\n          </DropdownMenuItem>\n        </DropdownMenuGroup>\n        <DropdownMenuSeparator />\n        <DropdownMenuItem variant=\"destructive\">\n          <LogOutIcon aria-hidden=\"true\" />\n          <span>Log out</span>\n        </DropdownMenuItem>\n      </DropdownMenuContent>\n    </DropdownMenu>\n  )\n}\n",
      "type": "registry:example"
    }
  ],
  "categories": [
    "avatar"
  ],
  "type": "registry:example"
}
