{
  "name": "love-ui",
  "version": "1.2.16",
  "private": false,
  "license": "MIT",
  "type": "module",
  "bin": {
    "loveui": "dist/index.js",
    "love-ui": "dist/index.js",
    "loveui-mcp": "dist/mcp-server.js"
  },
  "files": [
    "dist",
    "registry"
  ],
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./registry/*": "./registry/*",
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.1",
    "menu": "link:@base-ui/react/menu",
    "postcss": "^8.5.6",
    "postcss-nested": "^7.0.2"
  },
  "scripts": {
    "build": "tsup",
    "postbuild": "node ./scripts/copy-registry.mjs",
    "prepack": "npm run build",
    "verify:registry": "node ./scripts/copy-registry.mjs",
    "clean": "rimraf dist registry"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.0"
  }
}
