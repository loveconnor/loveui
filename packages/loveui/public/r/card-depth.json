{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "card-depth",
  "description": "Stacked depth card",
  "registryDependencies": [
    "@loveui/button",
    "@loveui/card"
  ],
  "files": [
    {
      "path": "registry/default/examples/card-depth.tsx",
      "content": "import { Button } from \"@/registry/default/ui/button\"\nimport {\n  Card,\n  CardContent,\n  CardDescription,\n  CardFooter,\n  CardHeader,\n  CardTitle,\n} from \"@/registry/default/ui/card\"\n\nexport default function CardDepth() {\n  return (\n    <div className=\"relative size-fit\">\n      <Card className=\"relative z-1 w-full max-w-xs\">\n        <CardHeader>\n          <CardTitle>Default Card</CardTitle>\n          <CardDescription>\n            This card uses the default size variant.\n          </CardDescription>\n        </CardHeader>\n        <CardContent>\n          <p>\n            Layered panels behind the card create a subtle stacked depth\n            effect.\n          </p>\n        </CardContent>\n        <CardFooter>\n          <Button variant=\"outline\" className=\"w-full\">\n            Action\n          </Button>\n        </CardFooter>\n      </Card>\n      <div className=\"absolute inset-4 -bottom-3 z-0 rounded-lg border bg-card shadow-md shadow-black/1\" />\n      <div className=\"absolute inset-2 -bottom-1.5 z-0 rounded-lg border bg-card shadow-md shadow-black/1\" />\n    </div>\n  )\n}\n",
      "type": "registry:example"
    }
  ],
  "categories": [
    "card"
  ],
  "type": "registry:example"
}
