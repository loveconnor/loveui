{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "paths": {
      "@/*": ["./*"],
      "collections/*": ["./.source/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "components/ui/code-block/src/components/code-block/blocks/**",
    "components/ui/code-block/src/components/code-block/client/**",
    "components/ui/code-block/src/components/code-block/mdx/**",
    "components/ui/code-block/src/components/ui/**",
    "components/ui/code-block/src/stores/**",
    "components/ui/code-block/src/utils/sugar-high/**",
    "registry/default/examples/**",
    "packages/*-pro",
    "packages/loveui/dist",
    "packages/loveui/packages",
    "packages/loveui/src",
    "packages/loveui/tsup.config.ts",
    "packages/loveui/registry"
  ]
}
