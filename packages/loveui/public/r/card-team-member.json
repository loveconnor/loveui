{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "card-team-member",
  "description": "Team member card",
  "registryDependencies": [
    "@loveui/avatar",
    "@loveui/badge",
    "@loveui/button",
    "@loveui/card"
  ],
  "files": [
    {
      "path": "registry/default/examples/card-team-member.tsx",
      "content": "import {\n  Avatar,\n  AvatarFallback,\n  AvatarImage,\n} from \"@/registry/default/ui/avatar\"\nimport { Badge } from \"@/registry/default/ui/badge\"\nimport { Button } from \"@/registry/default/ui/button\"\nimport {\n  Card,\n  CardContent,\n  CardFooter,\n  CardHeader,\n  CardTitle,\n} from \"@/registry/default/ui/card\"\n\nexport default function CardTeamMember() {\n  return (\n    <Card className=\"w-full max-w-xs gap-5\">\n      <CardHeader className=\"flex flex-row items-start gap-4\">\n        <Avatar className=\"size-12 border\">\n          <AvatarImage\n            src=\"https://images.unsplash.com/photo-1517841905240-472988babdf9?w=96&h=96&fit=crop\"\n            alt=\"Riley Scott\"\n          />\n          <AvatarFallback>RS</AvatarFallback>\n        </Avatar>\n        <div className=\"min-w-0 flex-1\">\n          <div className=\"flex items-start justify-between gap-3\">\n            <div className=\"min-w-0\">\n              <CardTitle>Riley Scott</CardTitle>\n              <p className=\"text-sm text-muted-foreground\">Product lead</p>\n            </div>\n            <Badge variant=\"success\">Online</Badge>\n          </div>\n        </div>\n      </CardHeader>\n      <CardContent className=\"space-y-4\">\n        <p className=\"text-sm leading-relaxed text-muted-foreground\">\n          Owns onboarding, activation, and roadmap planning for the growth\n          product team.\n        </p>\n        <div className=\"flex flex-wrap gap-1.5\">\n          <Badge variant=\"secondary\">Strategy</Badge>\n          <Badge variant=\"secondary\">Research</Badge>\n          <Badge variant=\"secondary\">Roadmap</Badge>\n        </div>\n      </CardContent>\n      <CardFooter className=\"gap-2\">\n        <Button className=\"flex-1\" size=\"sm\">\n          Message\n        </Button>\n        <Button className=\"flex-1\" variant=\"outline\" size=\"sm\">\n          Profile\n        </Button>\n      </CardFooter>\n    </Card>\n  )\n}\n",
      "type": "registry:example"
    }
  ],
  "categories": [
    "card"
  ],
  "type": "registry:example"
}
