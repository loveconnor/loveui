{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "logo-cloud-five",
  "type": "registry:block",
  "title": "logo-cloud/five",
  "description": "Flexible wrap logo cloud for dense brand lists.",
  "files": [
    {
      "path": "registry/default/blocks/logo-cloud-5/app/page.tsx",
      "type": "registry:page",
      "target": "components/blocks/logo-cloud/five/app/page.tsx",
      "content": "import { LogoCloud } from \"../components/logo-cloud\";\n\nexport default function Page() {\n\treturn (\n\t\t<div className=\"min-h-screen w-full place-content-center p-4\">\n\t\t\t<div className=\"w-full\">\n\t\t\t\t<h2 className=\"mb-5 text-center text-lg text-muted-foreground\">\n\t\t\t\t\tAlready used by{\" \"}\n\t\t\t\t\t<span className=\"font-medium text-primary\">Best in the Game</span>\n\t\t\t\t</h2>\n\t\t\t\t<div className=\"relative mx-auto max-w-3xl\">\n\t\t\t\t\t<LogoCloud />\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\t);\n}\n"
    },
    {
      "path": "registry/default/blocks/logo-cloud-5/components/logo-cloud.tsx",
      "type": "registry:component",
      "target": "components/blocks/logo-cloud/five/components/logo-cloud.tsx",
      "content": "import ClaudeLogo from \"./logos/claude-wordmark.svg\";\nimport ClerkLogo from \"./logos/clerk-wordmark.svg\";\nimport GithubLogo from \"./logos/github-wordmark.svg\";\nimport NvidiaLogo from \"./logos/nvidia-wordmark.svg\";\nimport OpenAILogo from \"./logos/openai-wordmark.svg\";\nimport SupabaseLogo from \"./logos/supabase-wordmark.svg\";\nimport TursoLogo from \"./logos/turso-wordmark.svg\";\nimport VercelLogo from \"./logos/vercel-wordmark.svg\";\n\ntype LogoSource = { src: string } | string;\n\nconst getLogoSrc = (source: LogoSource) =>\n\ttypeof source === \"string\" ? source : source.src;\n\nexport function LogoCloud() {\n\treturn (\n\t\t<div className=\"relative flex flex-wrap items-center justify-center gap-x-10 gap-y-8 py-6 sm:gap-x-12 sm:gap-y-12\">\n\t\t\t{logos.map((logo) => (\n\t\t\t\t<img\n\t\t\t\t\talt={logo.alt}\n\t\t\t\t\tclassName=\"pointer-events-none h-5 w-fit select-none dark:brightness-0 dark:invert\"\n\t\t\t\t\theight=\"auto\"\n\t\t\t\t\tkey={logo.alt}\n\t\t\t\t\tloading=\"lazy\"\n\t\t\t\t\tsrc={getLogoSrc(logo.src)}\n\t\t\t\t\twidth=\"auto\"\n\t\t\t\t/>\n\t\t\t))}\n\t\t</div>\n\t);\n}\n\nconst logos = [\n\t{\n\t\tsrc: VercelLogo,\n\t\talt: \"Vercel Logo\",\n\t},\n\t{\n\t\tsrc: SupabaseLogo,\n\t\talt: \"Supabase Logo\",\n\t},\n\t{\n\t\tsrc: OpenAILogo,\n\t\talt: \"OpenAI Logo\",\n\t},\n\t{\n\t\tsrc: TursoLogo,\n\t\talt: \"Turso Logo\",\n\t},\n\n\t{\n\t\tsrc: GithubLogo,\n\t\talt: \"GitHub Logo\",\n\t},\n\t{\n\t\tsrc: ClaudeLogo,\n\t\talt: \"Claude AI Logo\",\n\t},\n\t{\n\t\tsrc: NvidiaLogo,\n\t\talt: \"Nvidia Logo\",\n\t},\n\t{\n\t\tsrc: ClerkLogo,\n\t\talt: \"Clerk Logo\",\n\t},\n];\n"
    },
