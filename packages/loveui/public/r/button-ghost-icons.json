  "files": [
    {
      "path": "registry/default/examples/button-ghost-icons.tsx",
      "content": "import { ArrowLeftIcon, ArrowRightIcon } from \"lucide-react\"\n\nimport { Button } from \"@/registry/default/ui/button\"\n\nexport default function ButtonGhostIcons() {\n  return (\n    <div className=\"flex flex-wrap items-center gap-3\">\n      <Button variant=\"ghost\">\n        <ArrowLeftIcon />\n        Previous\n      </Button>\n      <Button variant=\"ghost\">\n        Next\n        <ArrowRightIcon />\n      </Button>\n    </div>\n  )\n}\n",
      "type": "registry:example"
    }
  ],
  "categories": [
    "button"
  ],
  "type": "registry:example"
